# Platform environment variables

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=1
LLM_MAX_TOKENS=20000

# ASR Configuration
ASR_PROVIDER=whisper
ASR_API_KEY=your-api-key-here
ASR_MODEL=whisper-1

# Platform Configuration
PLATFORM_APP_NAME=OpenShrimp
PLATFORM_DEBUG=true
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=8000
PLATFORM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PLATFORM_DATA_DIR=./data
PLATFORM_DB_URL=sqlite+aiosqlite:///./data/platform.db

# Authentication
# AUTH_SECRET_KEY=your-secret-key-here
# AUTH_DEFAULT_ADMIN_USERNAME=admin
# AUTH_DEFAULT_ADMIN_PASSWORD=admin123
